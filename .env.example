# Copy to .env and fill in.
# All Kuwenta vars use the KUWENTA_ prefix to avoid collisions with system env
# (e.g. a system-wide DATABASE_URL pointing at a different database).

# --- Core ---
KUWENTA_APP_ENV=development
KUWENTA_JWT_SECRET=change-me-to-a-long-random-string
KUWENTA_JWT_ALGORITHM=HS256
KUWENTA_JWT_EXPIRE_MINUTES=10080  # 7 days

# --- Database ---
KUWENTA_DATABASE_URL=sqlite+aiosqlite:///./data/kuwenta.db

# --- LLM providers (free tiers) ---
KUWENTA_GEMINI_API_KEY=
KUWENTA_GROQ_API_KEY=
KUWENTA_OLLAMA_BASE_URL=http://localhost:11434

# Default provider per purpose. Allowed: gemini, groq, ollama
KUWENTA_LLM_PROVIDER_CATEGORIZATION=gemini
KUWENTA_LLM_PROVIDER_QA=gemini
KUWENTA_LLM_PROVIDER_OCR=gemini
KUWENTA_LLM_PROVIDER_INSIGHTS=gemini

# Gemini free-tier rate limit (req/min)
KUWENTA_GEMINI_RATE_LIMIT_PER_MIN=15

# --- Storage ---
KUWENTA_RECEIPT_STORAGE_DIR=./data/receipts

# --- Frontend (no prefix — Next.js needs the NEXT_PUBLIC_ prefix as-is) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
